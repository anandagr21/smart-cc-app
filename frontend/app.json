{
  "expo": {
    "name": "Card Analyser",
    "slug": "card-optimizer",
    "version": "1.0.0",
    "scheme": "smartcc",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smartcc.app"
    },
    "android": {
      "package": "com.smartcc.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-router",
      "expo-web-browser",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.768994784419-gftc3oigrn4snh3f2d22i2s0c1p2k2a9"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "smart-cc-app",
          "organization": "smart-cc"
        }
      ],
      "expo-updates"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "18741011-a88f-42ff-b38b-02ceabdc13c8"
      }
    },
    "owner": "akaovia-org",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/18741011-a88f-42ff-b38b-02ceabdc13c8"
    }
  }
}